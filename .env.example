TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# PAT GitHub (classic) avec scopes repo+project — requis pour gh project item-add/item-edit
# Créer sur : GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
GH_PAT=ghp_your_personal_access_token_here
MONGODB_URI=mongodb+srv://user:pwd@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=agent-binance
# ANTHROPIC_API_KEY est intentionnellement ignorée par le bot (voir binance-bot/core/env.py).
# Le bot fonctionne uniquement en mode abonnement Claude — aucun fallback pay-per-use.
# Ne pas décommenter : cette clé ne sera jamais chargée dans le processus.
# ANTHROPIC_API_KEY=
# Napkin AI — génération de visuels depuis les docs (scripts/generate_visuals.py)
# Token récupérable sur https://app.napkin.ai → Réglages → API
NAPKIN_API_TOKEN=
