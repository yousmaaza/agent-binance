shape: sequence_diagram

user: "Utilisateur"
tg: "Telegram"
srv: "webhook_server.py"
cl: "Claude CLI"
tv: "TradingView MCP"
bn: "Binance API"
mg: "MongoDB Atlas"

user -> tg: "/trade"
tg -> srv: "update getUpdates"
srv -> srv: "acquire_lock"
srv -> tg: "Cycle demarre..."
srv -> cl: "subprocess stream-json"
cl -> bn: "Phase 0 - get-account"
bn -> cl: "solde USDC, trades ouverts"
cl -> tg: "Phase 0 OK"
cl -> tv: "Phase 1 - top_gainers, sentiment"
tv -> cl: "liste coins"
cl -> tg: "Phase 1 OK"
cl -> tv: "Phase 2 - coin_analysis 4h et 1d"
tv -> cl: "signaux techniques"
cl -> tg: "Phase 2 OK"
cl -> cl: "Phase 3 - Scoring 0-10"
cl -> tg: "Phase 3 OK - N candidats"
cl -> cl: "Phase 4 - Sizing ATR risk 1%"
cl -> tg: "Phase 4 OK"
cl -> bn: "Phase 5 - order-list-otoco"
bn -> cl: "ordres confirmes"
cl -> tg: "Phase 5 OK - N ordres places"
cl -> cl: "Phase 6 - rapport reports/MD"
cl -> mg: "Phase 7 - upsert cycles"
mg -> cl: "OK"
cl -> tg: "Resume final FR"
srv -> srv: "release_lock"
